@{
    Layout = "_Layout";
    ViewData["Title"] = "Strava Ex - Home";
}


<!-- Material Design for Bootstrap (MDB) -->
<link href="https://cdnjs.cloudflare.com/ajax/libs/mdb-ui-kit/7.3.0/mdb.min.css"
      rel="stylesheet" />
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
      rel="stylesheet" />


<main class="container my-5">
    <!-- Hero Section -->
    <section class="text-center mb-5">
        <h1 class="display-4 fw-bold text-primary mb-3">
            Strava Ex
        </h1>
        <p class="lead text-muted mb-4">
            Connect your Strava account to view personalized activity stats, progress insights, and performance analytics.
        </p>
        <a href="/StravaDashboard/Index" class="btn btn-primary btn-lg ripple-surface">
            <i class="fa-brands fa-strava me-2"></i> Connect with Strava
        </a>
    </section>   
</main>


<script src="https://cdnjs.cloudflare.com/ajax/libs/mdb-ui-kit/7.3.0/mdb.min.js"></script>
